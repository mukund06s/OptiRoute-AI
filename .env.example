# OptiRoute Docker Compose environment (copy to .env at repository root)
# Never commit real secrets — placeholders only.

# PostgreSQL
POSTGRES_USER=optiroute
POSTGRES_PASSWORD=optiroute
POSTGRES_DB=optiroute_db

# Backend
NODE_ENV=production
BACKEND_PORT=5000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUST_PROXY=false
ML_SERVICE_URL=http://ml-service:8000

# Frontend (browser-facing API URL)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_NAME=OptiRoute
FRONTEND_PORT=3000

# ML Service
ML_PORT=8000
ML_MODEL_PATH=models/risk_model.pkl
ML_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://backend:5000

# Optional external integrations (placeholders)
OPENWEATHER_API_KEY=
N8N_WEBHOOK_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
