{
  "name": "optiroute-backend",
  "version": "1.0.0",
  "description": "OptiRoute Node.js/Express API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:ci": "eslint -c .eslintrc.ci.json src --ext .ts --max-warnings 20",
    "lint:fix": "eslint src --ext .ts --fix",
    "test:ci": "node scripts/run-ci-tests.mjs",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
    "prisma:seed": "tsx ../prisma/seed.ts"
  },
  "keywords": [
    "optiroute",
    "logistics",
    "express"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@langchain/anthropic": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "langchain": "^0.3.0",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "tsx ../prisma/seed.ts"
  }
}
